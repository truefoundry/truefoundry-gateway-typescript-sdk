# Paths Fern's TypeScript generator must leave alone on every regen. Hand-
# written helpers, their tests, and the top-level src/index.ts (which re-
# exports both Fern-generated symbols and helpers) live under stable paths so
# users can import them across releases without Fern overwriting them.
src/helpers/
src/index.ts
tests/mergeAssistantMessage.test.ts
.github/workflows/ci.yml
