{
    "name": "truefoundry-gateway-sdk",
    "version": "0.0.0",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/truefoundry/truefoundry-gateway-typescript-sdk.git"
    },
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./serialization": {
            "import": {
                "types": "./dist/esm/serialization/index.d.mts",
                "default": "./dist/esm/serialization/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/serialization/index.d.ts",
                "default": "./dist/cjs/serialization/index.js"
            },
            "default": "./dist/cjs/serialization/index.js"
        },
        "./private_": {
            "import": {
                "types": "./dist/esm/api/resources/private/exports.d.mts",
                "default": "./dist/esm/api/resources/private/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/private/exports.d.ts",
                "default": "./dist/cjs/api/resources/private/exports.js"
            },
            "default": "./dist/cjs/api/resources/private/exports.js"
        },
        "./private_/agents": {
            "import": {
                "types": "./dist/esm/api/resources/private/resources/agents/exports.d.mts",
                "default": "./dist/esm/api/resources/private/resources/agents/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/private/resources/agents/exports.d.ts",
                "default": "./dist/cjs/api/resources/private/resources/agents/exports.js"
            },
            "default": "./dist/cjs/api/resources/private/resources/agents/exports.js"
        },
        "./private_/agents/sessions": {
            "import": {
                "types": "./dist/esm/api/resources/private/resources/agents/resources/sessions/exports.d.mts",
                "default": "./dist/esm/api/resources/private/resources/agents/resources/sessions/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/private/resources/agents/resources/sessions/exports.d.ts",
                "default": "./dist/cjs/api/resources/private/resources/agents/resources/sessions/exports.js"
            },
            "default": "./dist/cjs/api/resources/private/resources/agents/resources/sessions/exports.js"
        },
        "./private_/agents/private_": {
            "import": {
                "types": "./dist/esm/api/resources/private/resources/agents/resources/private/exports.d.mts",
                "default": "./dist/esm/api/resources/private/resources/agents/resources/private/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/private/resources/agents/resources/private/exports.d.ts",
                "default": "./dist/cjs/api/resources/private/resources/agents/resources/private/exports.js"
            },
            "default": "./dist/cjs/api/resources/private/resources/agents/resources/private/exports.js"
        },
        "./private_/agents/private_/draftSessions": {
            "import": {
                "types": "./dist/esm/api/resources/private/resources/agents/resources/private/resources/draftSessions/exports.d.mts",
                "default": "./dist/esm/api/resources/private/resources/agents/resources/private/resources/draftSessions/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/private/resources/agents/resources/private/resources/draftSessions/exports.d.ts",
                "default": "./dist/cjs/api/resources/private/resources/agents/resources/private/resources/draftSessions/exports.js"
            },
            "default": "./dist/cjs/api/resources/private/resources/agents/resources/private/resources/draftSessions/exports.js"
        },
        "./private_/agents/private_/sessions": {
            "import": {
                "types": "./dist/esm/api/resources/private/resources/agents/resources/private/resources/sessions/exports.d.mts",
                "default": "./dist/esm/api/resources/private/resources/agents/resources/private/resources/sessions/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/private/resources/agents/resources/private/resources/sessions/exports.d.ts",
                "default": "./dist/cjs/api/resources/private/resources/agents/resources/private/resources/sessions/exports.js"
            },
            "default": "./dist/cjs/api/resources/private/resources/agents/resources/private/resources/sessions/exports.js"
        },
        "./package.json": "./package.json",
        "./agents": {
            "types": "./dist/cjs/agents/index.d.ts",
            "import": {
                "types": "./dist/esm/agents/index.d.mts",
                "default": "./dist/esm/agents/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/agents/index.d.ts",
                "default": "./dist/cjs/agents/index.js"
            }
        }
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {},
    "devDependencies": {
        "webpack": "^5.105.4",
        "ts-loader": "^9.5.4",
        "vitest": "^4.1.1",
        "msw": "2.11.2",
        "@types/node": "^20.0.0",
        "typescript": "~5.9.3",
        "@biomejs/biome": "2.4.10"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
